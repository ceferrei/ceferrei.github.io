@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div id="myCarousel" class="carousel slide" data-ride="carousel">
	<ol class="carousel-indicators">
		<li data-target="#myCarousel" data-slide-to="0" class="active"></li>
		<li data-target="#myCarousel" data-slide-to="1" class="active"></li>
		<li data-target="#myCarousel" data-slide-to="2" class="active"></li>
	</ol>
	<div class="carousel-inner">
		<div class="carousel-item active">
			<img src="./AI3.jpg" alt="ai image">
			<div class="carousel-caption d-none d-md-block">
				<h1>AI-Powered Product Planning and Testing</h1>
				<p>Our advanced AI technology allows you to seamlessly integrate and test your product planning in real-world machine configurations.  <br /><span class="highlight-text">Ensure the perfect match between your plan and the actual placement of products with confidence.</span></p>
				<br />
                <a href="#contact" class="btn btn-lg btn-primary">Get Appointment</a>
                <a href="#about" class="btn btn-lg btn-secondary">Learn More</a>
			</div>
		</div>
		<div class="carousel-item ">
			<img src="./AI4.jpg" alt="ai image">
			<div class="carousel-caption d-none d-md-block">
				<h1>Simplify Product Management</h1>
				<p>Streamline your product inventory with our user-friendly tools.  <br /><span class="highlight-text">Manage, add, and remove products effortlessly, making product management a breeze.</span></p>
				<br />
				<a href="#contact" class="btn btn-lg btn-primary">Get Appointment</a>
				<a href="#about" class="btn btn-lg btn-secondary">Learn More</a>

			</div>
		</div>
		<div class="carousel-item ">
			<img src="./AI2.jpg" alt="ai image">
			<div class="carousel-caption d-none d-md-block">
				<h1>Boost Efficiency with AI</h1>
				<p>Harness the power of AI to ensure your product planning aligns perfectly with your real-world machine configurations. <br /><span class="highlight-text">Minimize downtime and maximize efficiency with confidence.</span></p>
				<br />
                <a href="#contact" class="btn btn-lg btn-primary">Get Appointment</a>
                <a href="#about" class="btn btn-lg btn-secondary">Learn More</a>

			</div>
		</div>
	</div>
	<a class="carousel-control-prev" href="#myCarousel" role="button" data-slide="prev">
		<span class="carousel-control-prev-icon" aria-hidden="true"></span>
		<span class="sr-only">Previous</span>
	</a>
	<a class="carousel-control-next" href="#myCarousel" role="button" data-slide="next">
		<span class="carousel-control-next-icon" aria-hidden="true"></span>
		<span class="sr-only">Next</span>
	</a>
</div>
<div class="container-heading">
    <div class="row">
        <div class="col-lg-6 offset-lg-3">
            <div class="section-heading wow bounceIn" data-wow-duration="1s" data-wow-delay="0.2s">
                <h6>Our Product</h6>
                <h2>Discover What We Do &amp; <span>Offer</span> To Our <em>Clients</em></h2>
            </div>
        </div>
    </div>
</div>

<div id="features" class="features section">
    <div class="container">
        <div class="row">
            <div class="col-lg-12 ">
                <div class="features-content">
                    <div class="row">
                        <div class="col-lg-3">
                            <div class="features-item first-feature wow fadeInUp" data-wow-duration="1s" data-wow-delay="0s">
                                <div class="first-number number">
                                    <h6>01</h6>
                                </div>
                                @*<div class="icon"></div>*@
                                <img class="icon-hover"  src="~/supply-chain.png" style="object-fit: cover;" width="80" height="80" />

                                <h4>Manage your products</h4>
                                <div class="line-dec"></div>
                                <p>Easily add, organize, and remove products in your inventory list.</p>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="features-item second-feature wow fadeInUp" data-wow-duration="1s" data-wow-delay="0.2s">
                                <div class="second-number number">
                                    <h6>02</h6>
                                </div>
                                @*<div class="icon"></div>*@
                                <img class="icon-hover" src="~/management.png" style="object-fit: cover;" width="80" height="80" />

                                <h4>Manage your display cases</h4>
                                <div class="line-dec"></div>
                                <p>Effortlessly set up and arrange your display cases for different products.</p>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="features-item third-feature wow fadeInUp" data-wow-duration="1s" data-wow-delay="0.4s">
                                <div class="third-number number">
                                    <h6>03</h6>
                                </div>
                                @*<div class="icon"></div>*@
                                <img class="icon-hover" src="~/inventory.png" style="object-fit: cover;" width="80" height="80" />

                                <h4>Create your planning</h4>
                                <div class="line-dec"></div>
                                <p>Establish a planned layout for your products within various machines.</p>
                            </div>
                        </div>
                        <div class="col-lg-3">
                            <div class="features-item fourth-feature last-features-item wow fadeInUp" data-wow-duration="1s" data-wow-delay="0.6s">
                                <div class="fourth-number number">
                                    <h6>04</h6>
                                </div>
                                @*<div class="icon"></div>*@
                                <img  class="icon-hover"  src="~/ai.png" style="object-fit: cover;" width="80" height="80"/>
                                <h4>Test your planning with AI</h4>
                                <div class="line-dec"></div>
                                <p>Utilize AI to check the compatibility of your planned layout with actual product placement.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="about" class="about-us section">
    <div class="container-our-product">
        <div class="row">
            
            <div class="section col-lg-6 align-self-center " data-wow-duration="1s" data-wow-delay="0.5s">
                <div class="section-heading">
                    <h6>Product Overview</h6>
                    <h2><span>Product Name</span>: AI-Powered Product Compatibility Verification</h2>
                </div>
                <p class="nea-description">Our innovative software simplifies product management and enables users to establish a product plan for various machines. For instance, in a beverage machine, define the number of shelves and products per shelf, positioning products seamlessly. Once a user captures an image of the machine, our embedded AI conducts a comprehensive compatibility test between the planned layout and the actual placement, ensuring precision and accuracy.</p>
             
                <div class="main-green-button"><a href="/Identity/Account/Register" target="_blank">Discover our product</a></div>
            </div>
            <div class="section col-lg-6">
                <div class="right-video wow fadeInLeft h-100 d-flex justify-content-center align-content-center" data-wow-duration="1s" data-wow-delay="0.5s" style="height: 400px;">
                    <iframe class="nea-video" width="560" height="315" src="./gravacao-tela.mp4" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                </div>

            </div>
        </div>
    </div>
</div>

<div id="about" class="about-us section">
    <div class="container-about ">
        <div class="row">
            <div class="section col-lg-6">
                <div class="left-video wow fadeInLeft h-100 d-flex justify-content-center align-content-center" data-wow-duration="1s" data-wow-delay="0.5s" style="height: 400px;">
                    <iframe class="nea-video" width="560" height="315" src="https://www.youtube.com/embed/FfEnLsBSg-4?si=r7E1979SJT4vTO9h" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen></iframe>
                </div>

            </div>
            <div class="section col-lg-6 align-self-center " data-wow-duration="1s" data-wow-delay="0.5s">
                <div class="section-heading">
                    <h6>About Us</h6>
                    <h2><span>Neadvance</span>: Innovating <em>machine vision and AI</em> for the global digital revolution</h2>
                    
                </div>
                <div class="row">
                    <div class="col-lg-4 col-sm-4">
                        <div class="about-item">
                            <h4>+$5M</h4>
                            <h6>Invested in Research & Development.</h6>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-4">
                        <div class="about-item">
                            <h4>+100</h4>
                            <h6>Projects successfully delivered.</h6>
                        </div>
                    </div>
                    <div class="col-lg-4 col-sm-4">
                        <div class="about-item">
                            <h4>+10</h4>
                            <h6>Countries rely on our solutions.</h6>
                        </div>
                    </div>
                </div>
                <p class="nea-description">
                    We develop innovative, high value-added solutions based on Computer Vision and Artificial Intelligence, contributing to the raising of the most demanding standards of quality, excellence and sustainability of production processes and services, responding the challenges imposed by Industry 4.0 and Digital Transformation in the various verticals of action.

                </p>
                <div class="main-green-button"><a href="https://neadvance.com/" target="_blank" >Discover company</a></div>
            </div>
        </div>
    </div>
</div>

 <div id="contact" class="contact-us section">
    <div class="container">
      <div class="row">
        <div class="col-lg-12 wow fadeInUp" data-wow-duration="0.5s" data-wow-delay="0.25s">
                <form id="contact" action="https://formsubmit.co/cmarcal@neadvance.com" enctype="multipart/form-data" method="post">
            <div class="row">
              <div class="col-lg-6 offset-lg-3">
                <div class="section-heading">
                  <h6>Contact Us</h6>
                  <h2>Fill Out The Form Below To <span>Get</span> In <em>Touch</em> With Us</h2>
                </div>
              </div>
              <div class="col-lg-9">
                <div class="row">
                  <div class="col-lg-6">
                    <fieldset>
                      <input type="text" name="name" id="name" placeholder="Name" autocomplete="on" required>
                    </fieldset>
                  </div>
                  <div class="col-lg-6">
                    <fieldset>
                      <input type="text" name="surname" id="surname" placeholder="Surname" autocomplete="on" required>
                    </fieldset>
                  </div>
                  <div class="col-lg-6">
                    <fieldset>
                      <input type="text" name="email" id="email"  placeholder="Your Email" required="">
                    </fieldset>
                  </div>
                  <div class="col-lg-6">
                    <fieldset>
                      <input type="text" name="subject" id="subject" placeholder="Subject" autocomplete="on">
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <textarea name="message" type="text" class="form-control" id="message" placeholder="Message" required=""></textarea>  
                    </fieldset>
                  </div>
                  <div class="col-lg-12">
                    <fieldset>
                      <button type="submit" id="form-submit" class="main-button ">Send Message Now</button>
                    </fieldset>
                  </div>
                </div>
              </div>
              <div class="col-lg-3">
                <div class="contact-info">
                  <ul>
                    <li>
                      <div class="icon">
                        <img src="./contact-icon-01.png" alt="email icon">
                      </div>
                            <a href="#">info@neadvance.com</a>
                    </li>
                    <li>
                      <div class="icon">
                        <img src="./contact-icon-02.png" alt="phone">
                      </div>
                            <a href="#">
                                253 145 430<br />
                                961 327 588
                            </a>
                    </li>
                    <li>
                      <div class="icon">
                        <img src="./contact-icon-03.png" alt="location">
                      </div>
                            <a href="#">
                                Rua do Parque Poente, Lt 35
                                4705-002 Sequeira, Braga
                                Portugal
                            </a>
                    </li>
                  </ul>
                </div>
              </div>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>