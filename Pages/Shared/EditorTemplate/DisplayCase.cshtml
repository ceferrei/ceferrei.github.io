@model MyProducts.Models.DisplayCase

@{
    ViewData.TemplateInfo.HtmlFieldPrefix = "DisplayCase";
}

<div asp-validation-summary="ModelOnly" class="text-danger"></div>

<div class="form-group mb-2">
    <label asp-for="Name" class="control-label"></label>
    <input asp-for="Name" class="form-control" />
    <span asp-validation-for="Name" class="text-danger"></span>
</div>

<div class="form-group mb-2">
    <label asp-for="ShelfCount" class="control-label"></label>
    <input asp-for="ShelfCount" class="form-control" />
    <span asp-validation-for="ShelfCount" class="text-danger"></span>
</div>

<div class="form-group mb-4">
    <label asp-for="ProductsPerShelf" class="control-label"></label>
    <input asp-for="ProductsPerShelf" class="form-control" />
    <span asp-validation-for="ProductsPerShelf" class="text-danger"></span>
</div>
