@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
</head>
<body>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card container-shadow">
                <div class="card-header">
                    <h1 class="text-center">@ViewData["Title"]</h1>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <div class="form-group">
                            <label for="inputEmail">Email</label>
                            <input type="email" asp-for="Input.Email" class="form-control" aria-required="true" id="inputEmail" />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>
                        <div class="form-group">
                            <br />
                            <p class="text-center">
                                <button id="registerSubmit" type="submit" class="button register__submit btn btn-primary btn-block btn-lg">
                                    <span class="button__text rounded">Reset Password</span>
                                    <i class="button__icon fas fa-chevron-right"></i>
                                </button>
                            </p>
                        </div>
                            <p class="text-center">
                                <a id="forgot-password" asp-page="./Register"> Go to Register</a>
                                <br />
                                <a id="forgot-password" asp-page="./Login">Go to Log In</a>
                                
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>
</body>
</html>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

<style>

    .register__submit {
        background: #007bff;
        font-size: 14px;
        margin-top: 0px;
        padding: 16px 20px;
        border-radius: 26px;
        border: 1px solid #D4D3E8;
        text-transform: uppercase;
        font-weight: 700;
        display: flex;
        align-items: center;
        width: 100%;
        color: white;
        box-shadow: 0px 2px 2px grey;
        cursor: pointer;
        transition: .2s;
        height: 44px;

    }

    .button__icon {
        font-size: 24px;
        margin-left: auto;
        color: white;
    }

    .card, .form-control {
        border-radius: 26px;
    }

    .container-shadow {
        box-shadow: 0px 0px 10px rgba(0, 0, 0, 0.5); /* Exemplo de sombra personalizada */
    }
    .form-control{
        height: 44px;
    }
    </style>

  