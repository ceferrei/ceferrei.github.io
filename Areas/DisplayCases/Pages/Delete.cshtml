@page
@model MyProducts.Areas.DisplayCases.Pages.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>DisplayCase</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DisplayCase.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DisplayCase.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DisplayCase.ShelfCount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DisplayCase.ShelfCount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DisplayCase.ProductsPerShelf)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DisplayCase.ProductsPerShelf)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DisplayCase.LastUpdatedDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DisplayCase.LastUpdatedDate)
        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="DisplayCase.DisplayCaseId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> 
        <a class="btn btn-secondary" asp-page="Index">Go back</a>
    </form>
