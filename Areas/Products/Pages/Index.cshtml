@page
@model MyProducts.Areas.ProductsInStock.Pages.IndexModel

@{
    ViewData["Title"] = "Index";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h1>Index</h1>
    <a asp-page="Create">
        <button class="btn btn-primary text-center px-4 py-2 d-flex justify-content-center align-items-center">
            <i data-feather="plus-circle"></i>
            <span class="ms-2">Create New</span>
        </button>

    </a>
</div>


<div class="table-container">
    <form asp-page-handler="Index" method="get">
        <div class="form-actions no-color">
            <div class="search-inputs">
                <div class="input-container">
                    <input type="text" name="searchString" class="form-control ps-3 pe-5" id="searchInput" value="@Model.SearchString" placeholder="Search for a product" />
                    @if(Model.SearchString != null && Model.SearchString.Length > 0)
                    {
                        <a class="clear-button" asp-page-handler="Index" type="button">
                            <i data-feather="x"></i>
                        </a>
                    }
                </div>
                <div class="button-container">
                    <button class="btn btn-primary" type="submit">
                        <span>Search</span>
                    </button>
                </div>
            </div>
        </div>
    </form>




    <table class="table table-striped text-center">
        <thead>
            <tr>
                <th scope="col" class="ps-4 py-4">
                    <a asp-page="Index" asp-route-sortOrder="@Model.NameSortParm">Product</a>
                </th>
                <th scope="col" class="py-4">
                    <a asp-page="Index" asp-route-sortOrder="@Model.DescriptionSortParm">Description</a>
                </th>

                <th scope="col" class="py-4">
                    Image
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.ProductInStock)
            {
                <tr class="align-middle">
                    <td class="ps-4">
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Description)
                    </td>
                    <td>
                        @if (item.Image != null)
                        {
                            <img src="@Url.Content(item.Image.Path)" height="64">
                        }
                    </td>
                    <td class="text-end pe-4">
                        <button class="rounded-circle bg-light border-0 shadow p-2 me-3">
                            <a asp-page="./Edit" asp-route-id="@item.ProductInStockId" style="color: orange;">
                                <i data-feather="edit"></i>
                            </a>
                        </button>

                        <button class="rounded-circle bg-light border-0 shadow p-2">
                            <a href="#" style="color: red;" data-toggle="modal" data-target="#deleteModal-@item.ProductInStockId">
                                <i data-feather="trash-2"></i>
                            </a>
                        </button>



                        <div class="modal fade" id="deleteModal-@item.ProductInStockId">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <div class="modal-header">
                                        <h5 class="modal-title" id="exampleModalLabel">Deletion confirmation</h5>
                                        <i class="icon-x-circle icon-close close" style="cursor: pointer;" data-feather="x-circle" data-dismiss="modal" aria-label="Close"></i>
                                    </div>
                                    <div class="modal-body">
                                        <p>Are you sure you want to delete this product?</p>
                                    </div>
                                    <div class="modal-footer">
                                        <form method="post" asp-page-handler="productDelete" asp-route-id="@item.ProductInStockId">
                                            <button type="submit" class="btn btn-danger">Delete</button>
                                            <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div id="confirmationMessage" class="confirmation-message">
        @if (TempData["CreateSuccessMessage"] != null)
        {
            <div class="alert alert-success" role="alert">
                @TempData["CreateSuccessMessage"]
            </div>
        }
        @if (TempData["DeleteSuccessMessage"] != null)
        {
            <div class="alert alert-success" role="alert">
                @TempData["DeleteSuccessMessage"]
            </div>
        }
    </div>

 </div>
@{
    var prevDisabled = !Model.ProductInStock.HasPreviousPage ? "disabled" : "";
    var nextDisabled = !Model.ProductInStock.HasNextPage ? "disabled" : "";
}


<div class="d-flex">
    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortParm"
       asp-route-searchString="@Model.SearchString"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-pageIndex="@(Model.ProductInStock.PageIndex - 1)"
       class="bg-primary d-flex justify-content-center align-items-center text-white me-2 p-1 rounded-circle @(prevDisabled)">
        <i data-feather="chevron-left"></i>
    </a>

    <a asp-page="./Index"
       asp-route-sortOrder="@Model.SortParm"
       asp-route-searchString="@Model.SearchString"
       asp-route-searchString="@ViewData["CurrentFilter"]"
       asp-route-pageIndex="@(Model.ProductInStock.PageIndex + 1)"
       class="bg-primary d-flex justify-content-center align-items-center text-white p-1 rounded-circle @(nextDisabled)">
        <i data-feather="chevron-right"></i>
    </a>
</div>





<style>
    .modal-body p {
        text-align: left;
    }
    .modal-content {
        border-radius: 26px;
        overflow: hidden;
    }

    .modal-header {
        background-color: #E9ECEF;
    }


    .modal-content {
        border-radius: 26px;
    }
    .confirmation-message {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 1000;
        display: none; /* A mensagem estará inicialmente oculta */
    }
    .disabled {
        pointer-events: none;
        opacity: 0.5;
    }


    .icon-close:hover {
        color: #DC3545;
    }

    .form-actions input[type="text"] {
        border-radius: 26px;
        padding: 8px;
    }
    .clear-all-button {
        float: right;
        margin-left: 10px; 
    }

    input.form-control {
        width: 20rem !important;
    }

    table th {
        color: rgba(20,124,191);
        text-align: left;
    }

    table th a {
        color: rgba(20,124,191);
    }

    table td {
        text-align: left;
    }

    table {
        border-spacing: 30px;
    }

   
    .form-actions {
        
        padding: 10px;
        border: 1px solid #ccc;
        background-color: #f0f0f0;
    }
    .btn{
        border-radius:20px;
    }

    .form-actions {
        padding: 20px;
        border: 1px solid #ccc;
        background-color: #f0f0f0;
    }


    .search-inputs {
        display: flex;
        align-items: center;
    }

    .input-container {
        position: relative;
        margin-right: 15px;
    }

    input[type="text"] {
        width: 200px;
        padding: 5px;
        border: 1px solid #ccc;
        border-radius: 5px;
    }

    input[type="text"]:focus{
        border: 1px solid rgba(20,124,191) !important
    }

    .clear-button {
        position: absolute;
        top: 50%;
        right: 5px;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        font-size: 16px;
    }

    .clear-button:focus {
        outline: none;
    }
    .button-container{
        align-items: right;
    }




</style>


<script>
    function clearInput(inputId) {
        var input = document.getElementById(inputId);
        input.value = "";
    }
   
    document.addEventListener("DOMContentLoaded", function () {
        var urlParams = new URLSearchParams(window.location.search);
        var createMessage = urlParams.get('CreateSuccessMessage');
        var deleteMessage = urlParams.get('DeleteSuccessMessage');

        var confirmationMessage = document.getElementById('confirmationMessage');

        if (createMessage) {
            confirmationMessage.innerHTML = '<div class="alert alert-success" role="alert">' + createMessage + '</div>';
            confirmationMessage.style.display = 'block';

            setTimeout(function () {
                confirmationMessage.style.display = 'none';
            }, 3000);
        }

        if (deleteMessage) {
            confirmationMessage.innerHTML = '<div class="alert alert-success" role="alert">' + deleteMessage + '</div>';
            confirmationMessage.style.display = 'block';

            setTimeout(function () {
                confirmationMessage.style.display = 'none';
            }, 3000);
        }
    });



</script>

