@page
@model MyProducts.Areas.Products.Pages.DeleteModel

@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

<h3>Are you sure you want to delete this?</h3>
<p class="text-danger">@Model.ErrorMessage</p>
<div>
    <h4>Product In Stock</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductInStock.Name)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductInStock.Name)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductInStock.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductInStock.Description)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ProductInStock.Image)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.ProductInStock.Image)

        </dd>
    </dl>
    
    <form method="post">
        <input type="hidden" asp-for="ProductInStock.ProductInStockId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> 
        <a asp-page="./Index" class="btn btn-secondary ">Go back</a>
    </form>
</div>
